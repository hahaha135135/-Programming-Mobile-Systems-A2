{
  "compilerOptions": {
    "target": "ES2016",
    "module": "ES2015",
    "lib": ["ES2016", "DOM"],
    "outDir": "./",
    "rootDir": "./",
    "removeComments": false,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "*.js"]
}